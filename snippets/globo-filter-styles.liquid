{% style %}
  @media (max-width: 767px) {
    #gf-tree .gf-scroll-wrap {
      position: relative;
      max-height: 220px;
    }

    #gf-tree .gf-scroll-wrap > .gf-scroll {
      max-height: 220px !important;
      overflow-y: auto !important;
      content-visibility: visible !important;
      -webkit-overflow-scrolling: touch;
      overscroll-behavior: contain;
    }

    #gf-tree .gf-scroll-wrap > .gf-scroll-fade {
      display: block;
      position: absolute;
      left: 0;
      right: 0;
      bottom: -3px;
      height: calc(2rem + 3px);
      pointer-events: none;
      z-index: 2;
      opacity: 0;
      transition: opacity 0.2s ease;
      background: linear-gradient(
        180deg,
        rgba(255, 255, 255, 0) 0%,
        rgba(255, 255, 255, 0.82) 65%,
        rgb(255, 255, 255) 92%,
        rgb(255, 255, 255) 100%
      );
    }

    #gf-tree .gf-scroll-wrap > .gf-scroll-fade.is-visible {
      opacity: 1;
    }
  }
{% endstyle %}
